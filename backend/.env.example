# ============================================================
# Nestoria backend — environment variables
# Copy this file to `.env` and fill in real values.
# ============================================================

# ---------- Server ----------
PORT=5000
# Comma-allowed list or single origin. In dev this is the Vite URL.
CORS_ORIGIN=http://localhost:5173

# ---------- PostgreSQL ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nestoria_db
DB_USER=postgres
DB_PASSWORD=change-me
# Set DB_SSL=true on Render (or any managed Postgres that requires TLS).
DB_SSL=false

# ---------- JWT ----------
# Use `openssl rand -base64 48` to generate a fresh secret.
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ---------- Supabase Storage (image uploads — optional) ----------
# Leave blank to disable the /api/upload endpoints; everything else still works.
SUPABASE_URL=
# Use the SERVICE_ROLE key (Project Settings → API → Service role), NOT the anon key.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_NAME=hotel-images

# ---------- Google OAuth (optional) ----------
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins must include your frontend URL (e.g. http://localhost:5173).
# Leaving this blank disables Google sign-in; email + password still works.
GOOGLE_CLIENT_ID=
